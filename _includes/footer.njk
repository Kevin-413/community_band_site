<div class="modal acb-contact-modal" id="contact-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="contact-modal-title">
    <div class="modal-background" data-contact-modal-close onclick="var modal=document.getElementById('contact-modal'); if (modal) { modal.classList.remove('is-active'); modal.setAttribute('aria-hidden','true'); } document.documentElement.classList.remove('is-clipped'); var trigger=document.querySelector('[data-contact-modal-open]'); if (trigger) { trigger.setAttribute('aria-expanded','false'); trigger.focus(); } return false;"></div>
    <div class="modal-card">
        <header class="modal-card-head">
            <p class="modal-card-title" id="contact-modal-title">Contact Amherst Community Band</p>
            <button class="delete" type="button" aria-label="Close contact modal" data-contact-modal-close onclick="var modal=document.getElementById('contact-modal'); if (modal) { modal.classList.remove('is-active'); modal.setAttribute('aria-hidden','true'); } document.documentElement.classList.remove('is-clipped'); var trigger=document.querySelector('[data-contact-modal-open]'); if (trigger) { trigger.setAttribute('aria-expanded','false'); trigger.focus(); } return false;"></button>
        </header>
        <form action="https://formspree.io/f/xwvjakkl" method="POST">
            <section class="modal-card-body">
                <p class="mb-3">Have a question about the band, performances, donations, or getting involved?</p>
                <p class="mb-4 acb-contact-demo-note"><strong>Contact form demo - not yet connected.</strong> After approval, this modal can be connected to Formspree.</p>

                <div class="field">
                    <label class="label" for="contact-demo-name">Your name</label>
                    <div class="control">
                        <input class="input" id="contact-demo-name" type="text" name="name" autocomplete="name" placeholder="Your name">
                    </div>
                </div>

                <div class="field">
                    <label class="label" for="contact-demo-email">Your email</label>
                    <div class="control">
                        <input class="input" id="contact-demo-email" type="email" name="email" autocomplete="email" placeholder="your.email@example.com">
                    </div>
                </div>

                <div class="field mb-4">
                    <label class="label" for="contact-demo-message">Message</label>
                    <div class="control">
                        <textarea class="textarea" id="contact-demo-message" name="message" rows="4" placeholder="How can we help?"></textarea>
                    </div>
                </div>

                <div class="acb-contact-captcha-placeholder mb-4" role="note" aria-live="polite">
                    CAPTCHA/spam protection will appear here after Formspree approval.
                </div>

                <p class="is-size-7 has-text-grey-dark mb-0">Approved public contact email is still pending confirmation.</p>
            </section>
            <footer class="modal-card-foot is-justify-content-space-between is-flex-wrap-wrap">
                <button class="button" type="button" data-contact-modal-close onclick="var modal=document.getElementById('contact-modal'); if (modal) { modal.classList.remove('is-active'); modal.setAttribute('aria-hidden','true'); } document.documentElement.classList.remove('is-clipped'); var trigger=document.querySelector('[data-contact-modal-open]'); if (trigger) { trigger.setAttribute('aria-expanded','false'); trigger.focus(); } return false;">Close</button>
                <button class="button is-primary has-text-weight-bold has-text-white" type="submit">Send Message</button>
            </footer>
        </form>
    </div>
</div>

