<section class="p-0">
<nav class="navbar is-primary" role="navigation" aria-label="main navigation">
    <div class="container">
        <div class="navbar-brand">
            {% image "src" + config.logoUrl, config.title, "180px" %}
            <a role="button" class="navbar-burger" data-target="navigation-headers" aria-label="menu" aria-expanded="false">
                <span aria-hidden="true"></span>
                <span aria-hidden="true"></span>
                <span aria-hidden="true"></span>
                <span aria-hidden="true"></span>
            </a>
            <button class="button is-light is-small has-text-weight-bold acb-contact-nav-button" type="button" aria-controls="contact-modal" aria-expanded="false" aria-haspopup="dialog" data-contact-modal-open onclick="var modal=document.getElementById('contact-modal'); if (modal) { modal.classList.add('is-active'); document.documentElement.classList.add('is-clipped'); modal.setAttribute('aria-hidden','false'); var name=document.getElementById('contact-demo-name'); if (name) { name.focus(); } } this.setAttribute('aria-expanded','true'); return false;">
                CONTACT
            </button>
        </div>

        <div id="navigation-headers" class="navbar-menu">
            <div class="navbar-start">
                {% for item in config.navbarMenu %}
                    {% if item.children and item.children.length %}
                        <div class="navbar-item has-dropdown is-hoverable">
                            <a class="navbar-link" href="{{item.url}}">
                                {{item.anchor}}
                            </a>
                            <div class="navbar-dropdown">
                                {% for child in item.children %}
                                    <a class="navbar-item" href="{{child.url}}">
                                        {{child.anchor}}
                                    </a>
                                {% endfor %}
                            </div>
                        </div>
                    {% else %}
                        <a class="navbar-item" href="{{item.url}}">
                            {{item.anchor}}
                        </a>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
    </div>
</nav>
</section>