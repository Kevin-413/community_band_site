---
layout: wide-page.njk
title: Concert Schedule
description: See the Amherst Community Band concert schedule with performance dates, times, and locations in Amherst and nearby communities.
---
<div class="columns">
    <div class="column is-one-half is-offset-1">
        <div class="container pl-6">
        <p>All concert times are listed in Eastern Time.</p>
        {% for category in config.concerts %}
            <h2 class="title is-2">{{ category.label }}</h2>
            {% for concert in category.schedule_items %}
                <h3 class="title is-4 mb-2">
                    {% if concert.start_iso %}
                        <time datetime="{{ concert.start_iso }}">{{ concert.date_and_time }}</time>
                    {% else %}
                        {{ concert.date_and_time }}
                    {% endif %}
                </h3>
                {% if concert.concert_name %}
                    <p class="subtitle is-6 mb-2">{{ concert.concert_name }}</p>
                {% endif %}
                <p class="subtitle is-6 mb-2">{{ concert.location_name or concert.location }}</p>
                {% if concert.location_address %}
                    <p class="subtitle is-6 mb-2">{{ concert.location_address }}</p>
                {% endif %}
                <br>
            {% endfor %}
        {% endfor %}
        </div>
    </div>
    <div class="column is-one-half is-vcentered">
        <figure class="has-soft-corners image is-4by3">
            <iframe class="has-ratio" width="640" height="390" src="https://www.youtube.com/embed/Ip_l4Xkx-84?si=pu06PLu09FGJQytm" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
        </figure>
    </div>
</div>

<script type="application/ld+json">
{% set eventBaseUrl = config.canonicalSiteUrl or config.siteUrl %}
{
    "@context": "https://schema.org",
    "@graph": [
        {% for category in config.concerts %}
            {% for concert in category.schedule_items %}
            {
                "@type": "MusicEvent",
                "name": "{{ concert.concert_name or (config.title + ' Concert') | escape }}",
                "startDate": "{{ concert.start_iso | escape }}",
                "description": "{{ concert.concert_name or (config.title + ' live concert performance') }}",
                "eventStatus": "https://schema.org/EventScheduled",
                "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
                "location": {
                    "@type": "Place",
                    "name": "{{ concert.location_name or concert.location }}",
                    "address": "{{ concert.location_address or concert.location }}"
                },
                "organizer": {
                    "@type": "Organization",
                    "name": "{{ config.title }}",
                    "url": "{{ eventBaseUrl }}"
                },
                "performer": {
                    "@type": "MusicGroup",
                    "name": "{{ config.title }}"
                },
                "url": "{{ eventBaseUrl }}{{ page.url }}"
            }{% if not (loop.last and loop.parent.last) %},{% endif %}
            {% endfor %}
        {% endfor %}
    ]
}
</script>
